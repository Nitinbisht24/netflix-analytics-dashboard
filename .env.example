# Copy this file to .env to override defaults. All values are optional —
# the app runs fine with no .env file at all.

# Server
PORT=5000
HOST=0.0.0.0
FLASK_DEBUG=0

# Force the SQLite analytics DB to rebuild from the raw CSVs on every
# startup (useful after editing data/raw/*.csv). Leave at 0 in normal use —
# the DB is built once and reused.
REBUILD_DB_ON_START=0

# How long (seconds) cached API responses are served before recomputing.
CACHE_TTL_SECONDS=300

# Flask session secret. Change this if you ever add session/cookie usage.
SECRET_KEY=dev-key-change-in-production
